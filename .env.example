# ============================================================================
# mimeo-zh 配置示例：复制本文件为 .env 后按需填写
# ============================================================================

# ---------------------------------------------------------------------------
# LLM Provider（二选一）
#   - openrouter: 全球路由，覆盖 OpenAI/Anthropic/Gemini/DeepSeek 等模型
#   - deepseek  : 直连 https://api.deepseek.com，国内网络友好
# ---------------------------------------------------------------------------
# MIMEO_PROVIDER=openrouter
MIMEO_PROVIDER=deepseek

# 默认模型：
#   - provider=openrouter 时默认 google/gemini-3.1-pro-preview
#   - provider=deepseek   时默认 deepseek-chat
# 也可以强制指定任意 slug
# MIMEO_MODEL=deepseek-chat          # DeepSeek V3 Chat
# MIMEO_MODEL=deepseek-reasoner      # DeepSeek R1 推理模型
# MIMEO_MODEL=deepseek/deepseek-chat # 走 OpenRouter 的 DeepSeek

# ---------------------------------------------------------------------------
# 凭证：按你使用的 provider 填对应那一行
# ---------------------------------------------------------------------------
# DeepSeek 官方：https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-...

# OpenRouter：https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# Parallel：https://platform.parallel.ai/  —— 搜索/抓取一定要用
PARALLEL_API_KEY=...

# ---------------------------------------------------------------------------
# 可选：DeepSeek 自建/私有网关地址（默认 https://api.deepseek.com）
# ---------------------------------------------------------------------------
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# ---------------------------------------------------------------------------
# 可选：OpenRouter 归因 headers
# ---------------------------------------------------------------------------
# OPENROUTER_SITE_URL=https://github.com/you/mimeo-zh
# OPENROUTER_APP_NAME=mimeo-zh
